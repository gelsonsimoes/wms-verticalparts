# Supabase Configuration
VITE_SUPABASE_URL=https://clakkpyzinuheubkhdep.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here
VITE_SUPABASE_PROJECT_ID=clakkpyzinuheubkhdep

# API Configuration
VITE_API_URL=http://localhost:3000
VITE_API_TIMEOUT=30000

# Feature Flags
VITE_ENABLE_REALTIME=true
VITE_ENABLE_SYNC=true
VITE_SYNC_INTERVAL=5000

# Mobile specific (para React Native)
VITE_MOBILE_OFFLINE_SYNC=true
VITE_MOBILE_QUEUE_ENABLED=true

# Development
VITE_DEBUG=false
VITE_LOG_LEVEL=info

# Authentication
VITE_AUTH_REDIRECT_URL=http://localhost:5173
VITE_SESSION_TIMEOUT=3600000

# For GitHub Actions / Server-side only (NÃO COMMITAR)
# SUPABASE_ACCESS_TOKEN=your_token_here
# SUPABASE_DB_PASSWORD=your_password_here
