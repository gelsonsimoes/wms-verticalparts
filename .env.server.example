# =============================================================
# WMS VerticalParts — Variáveis de Ambiente do SERVIDOR (VPS)
# Arquivo real no VPS: /var/www/wms-verticalparts/.env
# NUNCA commitar este arquivo com valores reais!
# =============================================================

# Servidor Express
PORT=3000
NODE_ENV=production

# Claude (Anthropic) — https://console.anthropic.com/
ANTHROPIC_API_KEY=SEU_TOKEN_AQUI

# Supabase — https://supabase.com/dashboard/project/clakkpyzinuheubkhdep/settings/api
VITE_SUPABASE_URL=https://clakkpyzinuheubkhdep.supabase.co
SUPABASE_SERVICE_ROLE_KEY=SEU_TOKEN_AQUI

# App URL (usado no convite de usuários)
VITE_APP_URL=https://wmsverticalparts.com.br

# Omie ERP (quando integração server-side for necessária)
# OMIE_APP_KEY=
# OMIE_APP_SECRET=
